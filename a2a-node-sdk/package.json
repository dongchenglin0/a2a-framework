{
  "name": "@fox/a2a-node-sdk",
  "version": "1.0.0",
  "description": "A2A Framework Node.js SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "generate-proto": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:./src/generated --grpc_out=grpc_tools_node_protoc_plugin,out=./src/generated --proto_path=../../a2a-proto/src/main/proto ../../a2a-proto/src/main/proto/a2a.proto",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.3",
    "@grpc/proto-loader": "^0.7.10",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "google-protobuf": "^3.21.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "license": "MIT"
}
